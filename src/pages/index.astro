    <script>
      // Мобильное меню
      const burger = document.querySelector(".header__burger");
      const mobileMenu = document.querySelector(".mobile-menu");
      const mobileMenuClose = document.querySelector(".mobile-menu__close");
      const mobileMenuLinks = document.querySelectorAll(".mobile-menu__link");

      burger?.addEventListener("click", () => {
        mobileMenu?.classList.add("mobile-menu--open");
        document.body.style.overflow = "hidden";
      });

      mobileMenuClose?.addEventListener("click", () => {
        mobileMenu?.classList.remove("mobile-menu--open");
        document.body.style.overflow = "";
      });

      mobileMenuLinks.forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu?.classList.remove("mobile-menu--open");
          document.body.style.overflow = "";
        });
      });

      // Модальные окна
      const modalForm = document.getElementById("modal-form");
      const modalSuccess = document.getElementById("modal-success");
      const openModalBtns = document.querySelectorAll(".js-open-modal");
      const closeBtns = document.querySelectorAll(".modal__close");
      const ctaForm = document.querySelector(".js-cta-form");
      const modalFormElement = document.querySelector(".modal__form");

      openModalBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          modalForm?.classList.add("modal--active");
          document.body.style.overflow = "hidden";
        });
      });

      closeBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          modalForm?.classList.remove("modal--active");
          modalSuccess?.classList.remove("modal--active");
          document.body.style.overflow = "";
        });
      });

      modalForm
        ?.querySelector(".modal__overlay")
        ?.addEventListener("click", () => {
          modalForm.classList.remove("modal--active");
          document.body.style.overflow = "";
        });

      modalSuccess
        ?.querySelector(".modal__overlay")
        ?.addEventListener("click", () => {
          modalSuccess.classList.remove("modal--active");
          document.body.style.overflow = "";
        });

      // Отправка формы CTA
      ctaForm?.addEventListener("submit", (e) => {
        e.preventDefault();
        modalSuccess?.classList.add("modal--active");
        document.body.style.overflow = "hidden";
        ctaForm.reset();
      });

      // Отправка формы в модальном окне
      modalFormElement?.addEventListener("submit", (e) => {
        e.preventDefault();
        modalForm?.classList.remove("modal--active");
        modalSuccess?.classList.add("modal--active");
        modalFormElement.reset();
      });

      // Плавный скролл к преимуществам
      const scrollBtns = document.querySelectorAll(".js-scroll-advantages");
      const advantagesSection = document.getElementById("advantages");

      scrollBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          advantagesSection?.scrollIntoView({ behavior: "smooth" });
        });
      });

      // Анимация переливания кнопки
      const shineBtn = document.querySelector(".btn--shine");
      if (shineBtn) {
        setInterval(() => {
          shineBtn.classList.add("btn--shine-animate");
          setTimeout(() => {
            shineBtn.classList.remove("btn--shine-animate");
          }, 1000);
        }, 7000);
      }

      // Кнопка наверх
      const scrollTopBtn = document.getElementById("scroll-top");

      window.addEventListener("scroll", () => {
        if (window.scrollY > 500) {
          scrollTopBtn?.classList.add("scroll-top--visible");
        } else {
          scrollTopBtn?.classList.remove("scroll-top--visible");
        }
      });

      scrollTopBtn?.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    </script>
